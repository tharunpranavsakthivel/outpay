{
  "name": "outpay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "alchemy:add-address": "bun scripts/add-alchemy-address.ts",
    "dev": "next dev -p 3001",
    "build": "next build --webpack",
    "start": "next start",
    "worker:payments": "bun workers/payment-listener.ts",
    "worker:provider-health": "bun workers/provider-health.ts",
    "worker:health": "bun workers/provider-health.ts",
    "worker:reconciler": "bun workers/reconciler.ts",
    "worker:alerts": "bun workers/alerts.ts",
    "worker:webhooks": "bun workers/webhook-dispatcher.ts",
    "db:clear": "bun scripts/db/clear.ts",
    "db:migrate": "bun scripts/db/migrate.ts up",
    "db:migrate:down": "bun scripts/db/migrate.ts down",
    "db:status": "bun scripts/db/migrate.ts status",
    "db:validate": "bun scripts/db/validate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1081.0",
    "better-auth": "^1.6.23",
    "bullmq": "^5.58.0",
    "ioredis": "^5.8.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "viem": "2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "overrides": {
    "postcss": "8.5.16"
  }
