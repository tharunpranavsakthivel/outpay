# Outpay
OUTPAY_SECRET_KEY=your_outpay_secret_key_here
OUTPAY_TEST_SECRET_KEY=your_outpay_test_secret_key_here
OUTPAY_LIVE_SECRET_KEY=your_outpay_live_secret_key_here
OUTPAY_PUBLIC_KEY=your_outpay_public_key_here
OUTPAY_WEBHOOK_SIGNING_SECRET=your_outpay_webhook_signing_secret_here

# Main app database URLs
DATABASE_URL="postgresql://postgres:my_strong_password@postgres.railway.internal:5432/outpay"
DATABASE_PUBLIC_URL="postgresql://postgres:my_strong_password@containers-us-west-12.railway.app:5432/outpay?sslmode=require"

# PostgreSQL runtime config
PGDATA="/var/lib/postgresql/data/pgdata"
PGDATABASE="outpay"
PGHOST="postgres.railway.internal"
PGPASSWORD="my_strong_password"
PGPORT="5432"
PGUSER="postgres"

# Postgres init variables
POSTGRES_DB="outpay"
POSTGRES_PASSWORD="my_strong_password"
POSTGRES_USER="postgres"

# Railway deployment behavior
RAILWAY_DEPLOYMENT_DRAINING_SECONDS="30"

# SSL certificate validity, usually only relevant if you are generating certs yourself
SSL_CERT_DAYS="365"

# App
APP_BASE_URL=http://localhost:3001

# Auth0
AUTH0_DOMAIN=your-auth0-domain.us.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret

# 64-character random string used to encrypt the session cookie
# Generate with:
# openssl rand -hex 32
AUTH0_SECRET=your-64-character-random-secret