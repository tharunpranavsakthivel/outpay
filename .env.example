# Outpay
OUTPAY_SECRET_KEY=your_outpay_secret_key_here
OUTPAY_TEST_SECRET_KEY=your_outpay_test_secret_key_here
OUTPAY_LIVE_SECRET_KEY=your_outpay_live_secret_key_here
OUTPAY_PUBLIC_KEY=your_outpay_public_key_here
OUTPAY_WEBHOOK_SIGNING_SECRET=your_outpay_webhook_signing_secret_here

# Main app database URLs
DATABASE_URL="postgresql://postgres:my_strong_password@db.example.com:5432/outpay"
DATABASE_PUBLIC_URL="postgresql://postgres:my_strong_password@db.example.com:5432/outpay"

# PostgreSQL runtime config
PGDATA="/var/lib/postgresql/data/pgdata"
PGDATABASE="outpay"
PGHOST="postgres.railway.internal"
PGPASSWORD="my_strong_password"
PGPORT="5432"
PGUSER="postgres"

# Per-service PostgreSQL pool ceilings. Keep the sum at or below the Railway
# plan's connection limit divided by the number of concurrent service instances.
OUTPAY_DATABASE_POOL_MAX="10"
OUTPAY_AUTH_POOL_MAX="5"

# Postgres init variables
POSTGRES_DB="outpay"
POSTGRES_PASSWORD="my_strong_password"
POSTGRES_USER="postgres"

# Railway deployment behavior
RAILWAY_DEPLOYMENT_DRAINING_SECONDS="30"

# SSL certificate validity, usually only relevant if you are generating certs yourself
SSL_CERT_DAYS="365"

# App
APP_BASE_URL=http://localhost:3001
BETTER_AUTH_URL=http://localhost:3001
OUTPAY_CHECKOUT_TTL_SECONDS=1800
OUTPAY_CHECKOUT_DETECTED_GRACE_SECONDS=600

# Transactional email (Resend)
# Use a sender address from a verified Resend domain.
RESEND_API_KEY=re_replace-with-your-resend-api-key
OUTPAY_EMAIL_FROM="Outpay <noreply@your-verified-domain.example>"
# Optional reply-to address for transactional messages.
OUTPAY_EMAIL_REPLY_TO=

# Alchemy Base provider
# Base mainnet RPC URL for thin JSON-RPC reads and webhook management auth.
ALCHEMY_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/replace-with-your-alchemy-api-key
# HMAC SHA-256 signing key used to verify X-Alchemy-Signature over the raw request body.
ALCHEMY_WEBHOOK_SIGNING_KEY=replace-with-your-alchemy-webhook-signing-key
# Address Activity webhook id used when registering tracked payout wallet addresses.
ALCHEMY_NOTIFY_WEBHOOK_ID=replace-with-your-alchemy-webhook-id
# Optional override for the webhook management API base URL if Alchemy changes environments.
ALCHEMY_NOTIFY_API_BASE_URL=https://dashboard.alchemy.com/api

# Chainstack secondary Base RPC provider
CHAINSTACK_BASE_RPC_URL=https://base-mainnet.core.chainstack.com/replace-with-your-chainstack-api-key
# Redis queue transport. Use Railway private networking in deployed environments;
# do not expose Redis publicly.
REDIS_URL=redis://localhost:6379
# Shared default ceiling for authenticated and public API routes not covered by
# a stricter architecture override.
API_RATE_LIMIT_PER_MINUTE=120
OUTPAY_SIGNUP_RATE_LIMIT_ENABLED=false
# Hosted checkout status polling limit for `/api/public/checkouts/[id]`.
CHECKOUT_STATUS_RATE_LIMIT_PER_MINUTE=60
MERCHANT_WEBHOOK_SECRET_ENCRYPTION_KEY=replace-with-a-32-byte-base64-key
OUTPAY_USDC_SLIGHT_OVERPAY_TOLERANCE=0.01
# Optional Slack-compatible webhook for critical operational alerts. Keep this
# value secret; it is never written to structured logs.
OUTPAY_ALERT_WEBHOOK_URL=
# Structured logger level. Use info in deployed environments unless debugging.
OUTPAY_LOG_LEVEL=info

# Provider routing and failover
RPC_PRIMARY_PROVIDER=alchemy
RPC_SECONDARY_PROVIDER=chainstack
RPC_TIMEOUT_MS=8000
RPC_FAILOVER_ENABLED=true
RPC_HEALTH_CHECK_INTERVAL_SECONDS=30

# Better Auth
# Generate with:
# openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret

# Tigris (S3-compatible) object storage - profile picture uploads
# Get access keys at console.storage.dev
AWS_ACCESS_KEY_ID=your-tigris-access-key-id
AWS_SECRET_ACCESS_KEY=your-tigris-secret-access-key
AWS_ENDPOINT_URL_S3=https://t3.storage.dev
AWS_ENDPOINT_URL_IAM=https://iam.storage.dev
AWS_REGION=auto
TIGRIS_BUCKET_NAME=your-bucket-name
